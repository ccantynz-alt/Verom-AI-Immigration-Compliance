{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/app",
      "dest": "/api/index.py"
    },
    {
      "src": "/login",
      "dest": "/api/index.py"
    },
    {
      "src": "/applicant",
      "dest": "/api/index.py"
    },
    {
      "src": "/attorney",
      "dest": "/api/index.py"
    },
    {
      "src": "/privacy",
      "dest": "/api/index.py"
    },
    {
      "src": "/terms",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
