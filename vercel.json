{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "",
  "framework": null,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/app",
      "destination": "/api/index.py"
    },
    {
      "source": "/login",
      "destination": "/api/index.py"
    },
    {
      "source": "/applicant",
      "destination": "/api/index.py"
    },
    {
      "source": "/attorney",
      "destination": "/api/index.py"
    },
    {
      "source": "/privacy",
      "destination": "/api/index.py"
    },
    {
      "source": "/terms",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
